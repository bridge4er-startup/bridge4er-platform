# Core app
DEBUG=False
SECRET_KEY=change-me-with-a-long-random-secret
ALLOWED_HOSTS=api.your-domain.com

# CORS / CSRF
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Database (PostgreSQL in production)
DATABASE_URL=postgresql://bridge4er_user:bridge4er_password@localhost:5432/bridge4er

# Storage provider (supabase or dropbox)
STORAGE_PROVIDER=supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_STORAGE_BUCKET=bridge4ER
SUPABASE_STORAGE_ROOT_PREFIX=bridge4er
SUPABASE_STORAGE_PUBLIC=0
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SIGNED_URL_TTL_SECONDS=3600
SUPABASE_REQUEST_TIMEOUT_SECONDS=45

# Public URLs
FRONTEND_PUBLIC_URL=https://your-domain.com
BACKEND_PUBLIC_URL=https://api.your-domain.com

# Security hardening
SECURE_SSL_REDIRECT=1
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=1
SECURE_HSTS_PRELOAD=1

# Runtime behavior
ALLOW_INSECURE_PAYMENT_VERIFICATION=0
ENABLE_DEMO_EXAM_SETS=0
DROPBOX_AUTO_SYNC_ENABLED=0
DROPBOX_AUTO_SYNC_COOLDOWN_SECONDS=600
DROPBOX_LIST_CACHE_TTL_SECONDS=3600
DROPBOX_LIST_CACHE_STALE_TTL_SECONDS=86400
DROPBOX_ALLOW_PUBLIC_LISTING=0

# Dropbox credentials (optional if STORAGE_PROVIDER=supabase)
DROPBOX_ACCESS_TOKEN=
DROPBOX_REFRESH_TOKEN=
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_USE_ENV_PROXY=0

# Optional bootstrap admin (used by manage.py ensure_admin)
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=
DJANGO_SUPERUSER_FULL_NAME=
DJANGO_SUPERUSER_MOBILE=
DJANGO_SUPERUSER_FIELD_OF_STUDY=

# Manual QR payment defaults (editable from admin dashboard)
QR_PAYMENT_TITLE=Bridge4ER Official Payment QR
QR_PAYMENT_ACCOUNT_NAME=
QR_PAYMENT_ACCOUNT_NUMBER=
QR_PAYMENT_CONTACT_EMAIL=
QR_PAYMENT_CONTACT_PHONE=
QR_PAYMENT_IMAGE_URL=

# Email notifications
DEFAULT_FROM_EMAIL=bridge4er@gmail.com
ADMIN_ALERT_EMAIL=
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=bridge4er@gmail.com
EMAIL_HOST_PASSWORD=
# Optional aliases if your host only supports custom key names:
# GMAIL_APP_PASSWORD=
# GOOGLE_APP_PASSWORD=
EMAIL_TIMEOUT_SECONDS=8
