# Core app
DEBUG=False
SECRET_KEY=change-me-with-a-long-random-secret
ALLOWED_HOSTS=bridge4er-api.onrender.com

# CORS / CSRF
CORS_ALLOWED_ORIGINS=https://bridge4er-platform.vercel.app
CSRF_TRUSTED_ORIGINS=https://bridge4er-platform.vercel.app

# Database (PostgreSQL in production)
DATABASE_URL=postgresql://bridge4er_user:bridge4er_password@localhost:5432/bridge4er

# Public URLs
FRONTEND_PUBLIC_URL=https://bridge4er-platform.vercel.app
BACKEND_PUBLIC_URL=https://bridge4er-api.onrender.com
PAYMENT_RESULT_PATH=/payment/result

# Security hardening
SECURE_SSL_REDIRECT=1
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=1
SECURE_HSTS_PRELOAD=1

# Runtime behavior
ALLOW_INSECURE_PAYMENT_VERIFICATION=0
ENABLE_DEMO_EXAM_SETS=0
DROPBOX_AUTO_SYNC_COOLDOWN_SECONDS=600
DROPBOX_LIST_CACHE_TTL_SECONDS=3600
DROPBOX_LIST_CACHE_STALE_TTL_SECONDS=86400

# Dropbox credentials
DROPBOX_ACCESS_TOKEN=
DROPBOX_REFRESH_TOKEN=
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_USE_ENV_PROXY=0

# Payment gateway keys
ESEWA_ENV=sandbox
ESEWA_PRODUCT_CODE=EPAYTEST
ESEWA_SECRET_KEY=
KHALTI_ENV=sandbox
KHALTI_SECRET_KEY=

# Email notifications
DEFAULT_FROM_EMAIL=bridge4er@gmail.com
ADMIN_ALERT_EMAIL=
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=bridge4er@gmail.com
EMAIL_HOST_PASSWORD=
